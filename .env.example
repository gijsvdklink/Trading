# Copy this file to .env and fill in your values.
# .env is in .gitignore and never committed.

# ── Trading212 ───────────────────────────────────────────────────────────────
# Get your API key: Trading212 app → Profile → API (bottom of menu)
# T212_DEMO=true  → demo account (fake money, safe to test)
# T212_DEMO=false → live account (real money)
T212_API_KEY=your_api_key_here
T212_DEMO=true

# ── Email notifications ───────────────────────────────────────────────────────
# Use a Gmail account with an App Password (not your normal password).
# Google Account → Security → 2-Step Verification → App Passwords
EMAIL_SENDER=you@gmail.com
EMAIL_PASSWORD=xxxx xxxx xxxx xxxx
EMAIL_RECIPIENT=you@gmail.com

# ── Agent settings ────────────────────────────────────────────────────────────
BUDGET_EUR=100
TOP_N_PER_TIER=5
HOLDING_DAYS=5
STOP_LOSS_PCT=0.05
